// ── Tag + view ─────────────────────────────────────────────────────────────
function selTag(el){document.querySelectorAll('.tag-b').forEach(b=>b.classList.remove('on'));el.classList.add('on');S.noteTag=el.dataset.t;}
function updPrev(){}// legacy, no-op

let noteView='topic';
let openTopics=new Set(['People','Process','Business','Formula','Agile','Ethics']);
let openNotes=new Set();

function setNoteView(v,el){
  noteView=v;
  document.querySelectorAll('.vtb').forEach(b=>b.classList.remove('on'));
  el.classList.add('on');
  renderNotes();
}
function toggleTopic(tag){
  if(openTopics.has(tag))openTopics.delete(tag);else openTopics.add(tag);
  renderNotes();
}
function toggleNoteRow(id){
  if(openNotes.has(id))openNotes.delete(id);else openNotes.add(id);
  renderNotes();
}

// ── Save note ──────────────────────────────────────────────────────────────
function saveNote(){
  const t=document.getElementById('nt').value.trim();
  const b=getNoteBody();
  if(!b){toast('Write something first','err');return;}
  const newNote={id:Date.now(),tag:S.noteTag,title:t||S.noteTag,body:b,date:new Date().toISOString().split('T')[0]};
  S.notes.unshift(newNote);
  // Auto-open this topic and this note
  openTopics.add(S.noteTag);
  openNotes.add(newNote.id);
  lsSaveNotesOnly();
  clearEditor();
  document.getElementById('nt').value='';
  renderNotes();toast('Note saved ✓','ok');
}
function delNote(id){
  if(!confirm('Delete this note?'))return;
  S.notes=S.notes.filter(n=>n.id!==id);
  openNotes.delete(id);
  lsSaveNotesOnly();renderNotes();toast('Note deleted');
}
function editNote(id){
  const n=S.notes.find(x=>x.id===id);if(!n)return;
  document.getElementById('nt').value=n.title;
  if(editorMode==='md'){
    document.getElementById('editor-md').value=n.body;
  } else {
    setEditorMode('rich');
    document.getElementById('editor').innerHTML=mdToHtml(n.body);
  }
  S.noteTag=n.tag;
  document.querySelectorAll('.tag-b').forEach(b=>b.classList.toggle('on',b.dataset.t===n.tag));
  S.notes=S.notes.filter(x=>x.id!==id);
  openNotes.delete(id);
  lsSaveNotesOnly();renderNotes();
  // scroll editor into view
  document.querySelector('.nform').scrollIntoView({behavior:'smooth',block:'start'});
  document.getElementById('nt').focus();
  toast('Note loaded for editing');
}
function toggleExpand(){}// legacy, no-op

// ── Render notes list ──────────────────────────────────────────────────────
function renderNotes(){
  const f=document.getElementById('nf').value;
  const srch=(document.getElementById('ns').value||'').toLowerCase();
  const fl=S.notes.filter(n=>(f==='all'||n.tag===f)&&(!srch||(n.body+n.title).toLowerCase().includes(srch)));
  document.getElementById('nc').textContent=fl.length+' note'+(fl.length===1?'':'s');

  if(!fl.length){
    document.getElementById('nl').innerHTML='<div class="empty"><div class="empty-i">📝</div><div style="font-size:13px">No notes yet.<br>Start writing on the left.</div></div>';
    return;
  }

  if(noteView==='list'){
    // Flat accordion rows (no topic grouping)
    document.getElementById('nl').innerHTML=fl.map(n=>`
      <div style="border:1px solid var(--border);border-radius:var(--r2);margin-bottom:7px;background:var(--bg2);overflow:hidden">
        <div class="note-row-header${openNotes.has(n.id)?' open':''}" onclick="toggleNoteRow(${n.id})" style="border-radius:var(--r2)">
          <span class="note-row-chevron">▶</span>
          <span class="ntag nt-${n.tag}">${n.tag}</span>
          <span class="note-row-title">${n.title}</span>
          <span class="note-row-date">${n.date}</span>
        </div>
        <div class="note-row-body${openNotes.has(n.id)?' open':''}">
          <div class="note-row-content">${mdToHtml(n.body)}</div>
          <div class="note-row-actions">
            <button class="btn btn-sm" onclick="editNote(${n.id});event.stopPropagation()">Edit</button>
            <button class="btn btn-sm btn-r" style="background:transparent;border:none" onclick="delNote(${n.id});event.stopPropagation()">Delete</button>
          </div>
        </div>
      </div>`).join('');
    return;
  }

  // ── Topic accordion view ────────────────────────────────────────────────
  const TOPIC_ORDER=['People','Process','Business','Formula','Agile','Ethics'];
  const groups={};
  fl.forEach(n=>{if(!groups[n.tag])groups[n.tag]=[];groups[n.tag].push(n);});
  const sortedTopics=TOPIC_ORDER.filter(t=>groups[t]).concat(Object.keys(groups).filter(t=>!TOPIC_ORDER.includes(t)));

  let html='';
  sortedTopics.forEach(tag=>{
    const notes=groups[tag];
    const isOpen=openTopics.has(tag);
    html+=`<div class="topic-group">
      <div class="topic-header${isOpen?' open':''}" onclick="toggleTopic('${tag}')">
        <span class="topic-chevron">▶</span>
        <span class="topic-tag nt-${tag}">${tag}</span>
        <span class="topic-name">${tag}</span>
        <span class="topic-count">${notes.length}</span>
      </div>
      <div class="topic-body${isOpen?' open':''}">
        ${notes.map(n=>{
          const isNoteOpen=openNotes.has(n.id);
          return`<div class="note-row">
            <div class="note-row-header${isNoteOpen?' open':''}" onclick="toggleNoteRow(${n.id})">
              <span class="note-row-chevron">▶</span>
              <span class="note-row-title">${n.title}</span>
              <span class="note-row-date">${n.date}</span>
            </div>
            <div class="note-row-body${isNoteOpen?' open':''}">
              <div class="note-row-content">${mdToHtml(n.body)}</div>
              <div class="note-row-actions">
                <button class="btn btn-sm" onclick="editNote(${n.id});event.stopPropagation()">Edit</button>
                <button class="btn btn-sm btn-r" style="background:transparent;border:none" onclick="delNote(${n.id});event.stopPropagation()">Delete</button>
              </div>
            </div>
          </div>`;
        }).join('')}
      </div>
    </div>`;
  });
  document.getElementById('nl').innerHTML=html;
}

