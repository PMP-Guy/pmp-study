// ── MODAL (timer-driven logging) ───────────────────────────────────────────
function openLog(){
  document.getElementById('log-modal').classList.add('open');
  document.getElementById('ml-s').value='';
  if(!document.getElementById('ml-t').value)document.getElementById('ml-t').value='';
  // fill summary from active session or defaults
  const h=S.activeSession?((Date.now()-S.activeSession.start)/3600000).toFixed(2):(S.timer.w/60).toFixed(2);
  const start=S.activeSession?S.activeSession.startStr:'—';
  const end=new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
  const elapsed=S.activeSession?formatElapsed(Math.floor((Date.now()-S.activeSession.start)/1000)):`${S.timer.w}:00`;
  document.getElementById('sess-summary').innerHTML=`<div style="display:flex;gap:16px;flex-wrap:wrap"><span>🕐 ${start} → ${end}</span><span>⏱ ${elapsed}</span><span>📚 ${parseFloat(h).toFixed(2)}h</span></div>`;
  document.getElementById('log-modal')._h=parseFloat(h);
}
function formatElapsed(secs){const m=Math.floor(secs/60),s=secs%60;return m+':'+String(s).padStart(2,'0');}
function closeM(id){document.getElementById(id).classList.remove('open');}
function logMod(){
  const sc=document.getElementById('ml-s').value,tp=document.getElementById('ml-t').value.trim();
  const h=document.getElementById('log-modal')._h||S.timer.w/60;
  const dt=new Date().toISOString().split('T')[0];
  const start=S.activeSession?S.activeSession.startStr:null;
  const end=new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
  const dur=start?start+'–'+end:null;
  S.sessions.push({date:dt,h:parseFloat(h.toFixed(2)),sc:sc?parseInt(sc):null,tp,qc:S.sT,dur});
  S.sR=0;S.sT=0;updateSBar();S.activeSession=null;hideSAB();
  lsSave();closeM('log-modal');renderDash();toast('Session logged ✓','ok');
}
document.getElementById('log-modal').addEventListener('click',function(e){if(e.target===this)closeM('log-modal');});

