const CIRC=283;
function tRender(){
  const totalSec=(S.tMode==='work'?S.timer.w:S.tMode==='short'?S.timer.s:S.timer.l)*60;
  const left=S.tLeft,m=Math.floor(left/60),sec=left%60;
  document.getElementById('t-disp').textContent=String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
  const fill=document.getElementById('tr-main');
  fill.style.strokeDashoffset=CIRC-(((totalSec-left)/totalSec)*CIRC);
  fill.className='tr-main'+(S.tMode!=='work'?' break':'');
  const phases={work:'FOCUS',short:'BREAK',long:'LONG BREAK'};
  const names={work:'Work session',short:'Short break ☕',long:'Long break 🌿'};
  document.getElementById('t-phase').textContent=phases[S.tMode]||'FOCUS';
  document.getElementById('tm-name').textContent=names[S.tMode]||'Work session';
  document.getElementById('tm-info').textContent='#'+(S.pCount+1)+' of 8';
  const btn=document.getElementById('t-btn');
  btn.textContent=S.tState==='running'?'Pause':S.tState==='paused'?'Resume':'Start';
  btn.className='tbn go'+(S.tState==='running'?' paused':'');
  let dots='';
  for(let i=0;i<8;i++){
    const c=i<S.pCount?'td done'+(i%4===3?' brk done':''):(i===S.pCount&&S.tMode==='work'&&S.tState==='running'?'td cur':'td');
    dots+=`<div class="${c}"></div>`;
  }
  document.getElementById('t-dots').innerHTML=dots;
  // sidebar stats
  document.getElementById('sb-p').textContent=S.todayPomCount+' today';
}
function tToggle(){
  if(S.tState==='idle'){
    // start a new work session → create active session
    if(S.tMode==='work'){
      S.activeSession={start:Date.now(),startStr:new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'})};
      showSAB();
    }
    S.tState='running';
    tInterval=setInterval(tTick,1000);
  } else if(S.tState==='paused'){
    S.tState='running';
    tInterval=setInterval(tTick,1000);
  } else {
    S.tState='paused';
    clearInterval(tInterval);
  }
  tRender();lsSave();
}
function tTick(){
  if(S.tLeft>0){S.tLeft--;tRender();updateSAB();}
  else tComplete();
}
function tComplete(){
  clearInterval(tInterval);S.tState='idle';
  if(S.tMode==='work'){
    S.pCount++;S.todayPomCount++;
    toast('Focus session complete! 🎉 Time for a break.','ok');
    S.tMode=S.pCount%4===0?'long':'short';
    // auto-open log modal
    if(S.activeSession){openLog();}
  } else {
    toast('Break over — let\'s focus!');
    S.tMode='work';
  }
  S.tLeft=(S.tMode==='work'?S.timer.w:S.tMode==='short'?S.timer.s:S.timer.l)*60;
  tRender();lsSave();
}
function tReset(){
  clearInterval(tInterval);S.tState='idle';S.tLeft=S.timer.w*60;S.tMode='work';
  if(S.activeSession){endSession(false);}
  tRender();lsSave();
}
function tSkip(){
