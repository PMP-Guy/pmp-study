#editor ol{padding-left:20px;margin:6px 0}
#editor li{margin:2px 0;color:var(--text2)}
#editor a{color:var(--blue);text-decoration:underline}
#editor hr{border:none;border-top:1px solid var(--border2);margin:10px 0}
#editor mark{border-radius:3px;padding:1px 2px}
#editor .hl-red{background:rgba(242,88,88,.25);color:var(--red)}
#editor .hl-amber{background:rgba(245,166,35,.22);color:var(--amber)}
#editor .hl-green{background:rgba(34,201,138,.2);color:var(--green)}
#editor .hl-blue{background:rgba(91,156,246,.2);color:var(--blue)}
#editor .hl-purple{background:rgba(167,139,250,.2);color:var(--purple)}
.editor-footer{display:flex;justify-content:space-between;align-items:center;padding:5px 10px;border-top:1px solid var(--border);background:var(--bg4)}
.editor-count{font-family:var(--fm);font-size:10px;color:var(--text4)}
.editor-hint{font-size:10px;color:var(--text4)}
/* Markdown mode toggle */
.mode-toggle{display:flex;gap:2px;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:2px;margin-bottom:10px}
.mode-btn{flex:1;padding:4px 8px;border-radius:4px;font-size:10px;font-family:var(--fm);border:none;background:transparent;color:var(--text3);cursor:pointer;transition:.14s;text-align:center}
.mode-btn.on{background:var(--bg5);color:var(--text);font-weight:500}
/* Note card list */
.ncount{font-family:var(--fm);font-size:10px;color:var(--text4);margin-top:4px}
.ntoolbar{display:flex;gap:7px;margin-bottom:12px;align-items:center}
.sw{position:relative;flex:1}
.sw input{padding-left:30px}
.sw-ic{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:12px;pointer-events:none}
.view-toggle{display:flex;gap:2px}
.vtb{width:26px;height:26px;border-radius:5px;border:1px solid var(--border2);background:transparent;color:var(--text3);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:11px;transition:.14s}
.vtb.on,.vtb:hover{background:var(--glass2);color:var(--text)}
.ncard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:14px 16px;margin-bottom:8px;transition:border-color .2s,transform .2s}
.ncard:hover{border-color:var(--border2);transform:translateY(-1px)}
.ncard.expanded .nbody-md{max-height:none}
.nhead{display:flex;align-items:flex-start;gap:7px;margin-bottom:8px}
.ntag{font-family:var(--fm);font-size:9px;padding:2px 7px;border-radius:100px;flex-shrink:0;font-weight:500;margin-top:2px}
.nt-People{background:var(--people2);color:var(--red);border:1px solid rgba(242,88,88,.2)}
.nt-Process{background:var(--process2);color:var(--green);border:1px solid rgba(34,201,138,.2)}
.nt-Business{background:var(--biz2);color:var(--blue);border:1px solid rgba(91,156,246,.2)}
.nt-Formula{background:var(--amber3);color:var(--amber);border:1px solid rgba(245,166,35,.2)}
.nt-Agile{background:var(--purple2);color:var(--purple);border:1px solid rgba(167,139,250,.2)}
.nt-Ethics{background:rgba(34,201,138,.1);color:var(--green);border:1px solid rgba(34,201,138,.2)}
.ntit{font-size:13px;font-weight:500;color:var(--text);flex:1;line-height:1.3}
.ndate{font-family:var(--fm);font-size:10px;color:var(--text4);flex-shrink:0;margin-top:1px}
/* Rendered markdown in cards */
.nbody-md{font-size:12.5px;color:var(--text2);line-height:1.75;max-height:180px;overflow:hidden;position:relative;transition:max-height .3s ease}
.nbody-md.expanded{max-height:none}
.nbody-md::after{content:'';position:absolute;bottom:0;left:0;right:0;height:32px;background:linear-gradient(transparent,var(--bg2));pointer-events:none;transition:opacity .2s}
.nbody-md.expanded::after{opacity:0}
.nbody-md h1{font-family:var(--fd);font-size:15px;font-weight:600;color:var(--text);margin:6px 0 3px}
.nbody-md h2{font-size:13px;font-weight:600;color:var(--text);margin:5px 0 2px;border-bottom:1px solid var(--border);padding-bottom:3px}
.nbody-md h3{font-size:12px;font-weight:600;color:var(--text2);margin:4px 0 2px;text-transform:uppercase;letter-spacing:.04em}
.nbody-md strong{font-weight:700;color:var(--text)}
.nbody-md em{font-style:italic;color:var(--text)}
.nbody-md code{font-family:var(--fm);font-size:11px;background:var(--bg4);color:var(--amber);padding:1px 4px;border-radius:3px;border:1px solid var(--border)}
.nbody-md pre{font-family:var(--fm);font-size:11px;background:var(--bg4);color:var(--green);padding:8px 10px;border-radius:var(--r);border:1px solid var(--border);overflow-x:auto;margin:5px 0;line-height:1.5}
.nbody-md blockquote{border-left:3px solid var(--amber);padding-left:10px;color:var(--text3);font-style:italic;margin:5px 0}
.nbody-md ul{padding-left:16px;margin:4px 0}
.nbody-md ol{padding-left:16px;margin:4px 0}
.nbody-md li{margin:2px 0}
.nbody-md a{color:var(--blue);text-decoration:underline}
.nbody-md hr{border:none;border-top:1px solid var(--border);margin:7px 0}
.nbody-md .hl-red{background:rgba(242,88,88,.25);color:var(--red);border-radius:3px;padding:1px 2px}
.nbody-md .hl-amber{background:rgba(245,166,35,.22);color:var(--amber);border-radius:3px;padding:1px 2px}
.nbody-md .hl-green{background:rgba(34,201,138,.2);color:var(--green);border-radius:3px;padding:1px 2px}
.nbody-md .hl-blue{background:rgba(91,156,246,.2);color:var(--blue);border-radius:3px;padding:1px 2px}
.nbody-md .hl-purple{background:rgba(167,139,250,.2);color:var(--purple);border-radius:3px;padding:1px 2px}
.nbody-raw{font-size:11.5px;color:var(--text3);line-height:1.65;white-space:pre-wrap;font-family:var(--fm);max-height:120px;overflow:hidden;display:none}
.nact{display:flex;gap:5px;margin-top:10px;opacity:0;transition:.16s;flex-wrap:wrap;align-items:center}
.ncard:hover .nact{opacity:1}
.expand-btn{font-size:10px;font-family:var(--fm);color:var(--text4);background:transparent;border:none;cursor:pointer;padding:0;margin-left:auto}
.expand-btn:hover{color:var(--text2)}
.empty{text-align:center;padding:48px 20px;color:var(--text3)}
.empty-i{font-size:32px;margin-bottom:10px;opacity:.3}
/* Accordion topic groups */
.topic-group{margin-bottom:8px;border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;background:var(--bg2)}
.topic-header{display:flex;align-items:center;gap:10px;padding:11px 14px;cursor:pointer;transition:background .15s;user-select:none}
.topic-header:hover{background:var(--bg3)}
.topic-header.open{background:var(--bg3)}
.topic-chevron{font-size:10px;color:var(--text3);transition:transform .2s;flex-shrink:0;font-family:var(--fm)}
.topic-header.open .topic-chevron{transform:rotate(90deg)}
.topic-tag{font-family:var(--fm);font-size:10px;padding:2px 8px;border-radius:100px;font-weight:500;flex-shrink:0}
.topic-name{font-size:13px;font-weight:500;color:var(--text);flex:1}
.topic-count{font-family:var(--fm);font-size:10px;color:var(--text3);background:var(--bg4);padding:2px 7px;border-radius:100px}
.topic-body{display:none;border-top:1px solid var(--border)}
.topic-body.open{display:block}
/* Individual note rows inside accordion */
.note-row{border-bottom:1px solid var(--border);cursor:pointer;transition:background .14s}
.note-row:last-child{border-bottom:none}
.note-row:hover{background:var(--bg3)}
.note-row-header{display:flex;align-items:center;gap:10px;padding:10px 14px}
.note-row-chevron{font-size:9px;color:var(--text3);transition:transform .2s;font-family:var(--fm);flex-shrink:0}
.note-row-header.open .note-row-chevron{transform:rotate(90deg)}
.note-row-title{font-size:13px;color:var(--text2);flex:1;line-height:1.3}
.note-row-header.open .note-row-title{color:var(--text);font-weight:500}
.note-row-date{font-family:var(--fm);font-size:10px;color:var(--text4);flex-shrink:0}
.note-row-body{display:none;padding:0 14px 14px;border-top:1px solid var(--border)}
.note-row-body.open{display:block}
.note-row-content{padding:10px;background:var(--bg4);border-radius:var(--r);font-size:12.5px;color:var(--text2);line-height:1.75}
.note-row-content h1{font-family:var(--fd);font-size:15px;font-weight:600;color:var(--text);margin:6px 0 3px}
.note-row-content h2{font-size:13px;font-weight:600;color:var(--text);margin:5px 0 2px;border-bottom:1px solid var(--border);padding-bottom:3px}
.note-row-content h3{font-size:12px;font-weight:600;color:var(--text2);margin:4px 0 2px;text-transform:uppercase;letter-spacing:.04em}
.note-row-content strong{font-weight:700;color:var(--text)}
.note-row-content em{font-style:italic}
.note-row-content code{font-family:var(--fm);font-size:11px;background:var(--bg2);color:var(--amber);padding:1px 4px;border-radius:3px;border:1px solid var(--border)}
.note-row-content pre{font-family:var(--fm);font-size:11px;background:var(--bg2);color:var(--green);padding:8px 10px;border-radius:var(--r);border:1px solid var(--border);overflow-x:auto;margin:5px 0}
.note-row-content blockquote{border-left:3px solid var(--amber);padding-left:10px;color:var(--text3);font-style:italic;margin:5px 0}
.note-row-content ul,.note-row-content ol{padding-left:16px;margin:4px 0}
.note-row-content li{margin:2px 0}
.note-row-content hr{border:none;border-top:1px solid var(--border);margin:7px 0}
.note-row-content .hl-red{background:rgba(242,88,88,.25);color:var(--red);border-radius:3px;padding:1px 2px}
.note-row-content .hl-amber{background:rgba(245,166,35,.22);color:var(--amber);border-radius:3px;padding:1px 2px}
.note-row-content .hl-green{background:rgba(34,201,138,.2);color:var(--green);border-radius:3px;padding:1px 2px}
.note-row-content .hl-blue{background:rgba(91,156,246,.2);color:var(--blue);border-radius:3px;padding:1px 2px}
.note-row-content .hl-purple{background:rgba(167,139,250,.2);color:var(--purple);border-radius:3px;padding:1px 2px}
.note-row-actions{display:flex;gap:6px;margin-top:10px;padding-top:8px;border-top:1px solid var(--border)}

/* REFS ─────────────────────── */
.ref-tabs{display:flex;gap:2px;margin-bottom:18px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:4px}
.ref-tab{flex:1;padding:7px 10px;border-radius:var(--r);font-size:11px;font-family:var(--fm);color:var(--text3);cursor:pointer;text-align:center;transition:.16s;border:none;background:transparent}
.ref-tab:hover{color:var(--text);background:var(--glass)}
.ref-tab.on{background:var(--glass3);color:var(--text);font-weight:500}
.ref-panel{display:none}.ref-panel.on{display:block}
.rsect{margin-bottom:22px}
.rtitle{font-family:var(--fm);font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;padding-bottom:7px;border-bottom:1px solid var(--border);margin-bottom:12px}
.ri-card{display:flex;gap:12px;padding:12px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);margin-bottom:8px;transition:all .18s;text-decoration:none;cursor:pointer}
.ri-card:hover{border-color:var(--border3);background:var(--bg3);transform:translateY(-1px)}
.ri-card a,.ri-card{color:inherit}
.ric{width:34px;height:34px;border-radius:var(--r);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.rtit{font-size:13px;font-weight:500;color:var(--text);display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.rbdg{font-family:var(--fm);font-size:9px;padding:2px 6px;border-radius:100px;background:rgba(34,201,138,.12);color:var(--green);border:1px solid rgba(34,201,138,.25)}
.rbdg-f{background:rgba(245,166,35,.12);color:var(--amber);border:1px solid rgba(245,166,35,.25)}
.rbdg-p{background:var(--purple2);color:var(--purple);border:1px solid rgba(167,139,250,.25)}
.rdsc{font-size:11px;color:var(--text3);margin-top:3px;line-height:1.6}
.rlink{font-family:var(--fm);font-size:10px;color:var(--blue);margin-top:4px;display:flex;align-items:center;gap:4px;text-decoration:none}
.rlink:hover{text-decoration:underline}
.rlink::after{content:'↗';font-size:9px}
.fg{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:7px}
.fcard{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px;transition:.15s}
.fcard:hover{background:var(--bg4);border-color:var(--border2)}
.fn{font-size:10px;color:var(--text3);margin-bottom:4px;font-family:var(--fm)}
.fv{font-family:var(--fm);font-size:12px;color:var(--blue);font-weight:500}

/* SETTINGS ─────────────────── */
.sg2{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start}
.scard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:20px;margin-bottom:14px;transition:border-color .2s}
.scard:hover{border-color:var(--border2)}
.stit{font-family:var(--fd);font-size:15px;font-weight:500;font-style:italic;color:var(--text);margin-bottom:14px}
.slf{margin-bottom:14px}
.slh{display:flex;justify-content:space-between;margin-bottom:4px;font-size:12px}
.slv{font-family:var(--fm);font-size:11px;font-weight:500;color:var(--amber)}
input[type=range]{-webkit-appearance:none;height:4px;background:var(--bg4);border-radius:2px;outline:none;border:none;padding:0;width:100%}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--amber);cursor:pointer;box-shadow:0 0 6px rgba(245,166,35,.4)}

/* MODAL ─────────────────────── */
.mov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px);z-index:1000;align-items:center;justify-content:center}
.mov.open{display:flex}
.modal{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r3);padding:24px;width:420px;max-width:93vw;box-shadow:var(--sh2);animation:mi .22s ease}
@keyframes mi{from{opacity:0;transform:scale(.96)}to{opacity:1;transform:scale(1)}}
.mtit{font-family:var(--fd);font-size:17px;font-weight:500;font-style:italic;color:var(--text);margin-bottom:18px;display:flex;justify-content:space-between;align-items:center}
.mx{background:transparent;border:none;color:var(--text3);font-size:18px;cursor:pointer;padding:2px 6px;border-radius:4px}
.mx:hover{background:var(--glass2);color:var(--text)}
.mact{display:flex;gap:7px;margin-top:16px}

/* TOAST ─────────────────────── */
.toast{position:fixed;bottom:20px;right:20px;background:var(--bg4);border:1px solid var(--border2);color:var(--text);font-size:12px;padding:10px 16px;border-radius:var(--r2);box-shadow:var(--sh2);z-index:2000;transform:translateY(18px);opacity:0;transition:all .28s cubic-bezier(.34,1.3,.64,1);pointer-events:none;display:flex;align-items:center;gap:8px;font-family:var(--ff)}
.toast.show{transform:translateY(0);opacity:1}
.toast.ok{border-color:rgba(34,201,138,.4);background:rgba(34,201,138,.1)}
.toast.err{border-color:rgba(242,88,88,.4);background:rgba(242,88,88,.1)}
.toast-dot{width:7px;height:7px;border-radius:50%;background:currentColor;flex-shrink:0}
.toast.ok .toast-dot{background:var(--green)}.toast.err .toast-dot{background:var(--red)}

/* MOBILE ─────────────────────── */
.mnav{display:none;background:var(--bg2);border-top:1px solid var(--border);position:fixed;bottom:0;left:0;right:0;z-index:100;padding:6px 0 max(6px,env(safe-area-inset-bottom))}
.mni-r{display:flex;justify-content:space-around}
.mni{display:flex;flex-direction:column;align-items:center;gap:2px;padding:4px 10px;cursor:pointer;color:var(--text4);font-family:var(--fm);font-size:9px;letter-spacing:.04em}
.mni.on{color:var(--amber)}
.mni svg{width:16px;height:16px;stroke:currentColor;stroke-width:1.8;fill:none}
@media(max-width:900px){
  .app{grid-template-columns:1fr}
  .rail,.sidebar{display:none}
  .mets{grid-template-columns:repeat(2,1fr)}
  .g2,.g3,.notes-layout,.sg2{grid-template-columns:1fr}
  .mnav{display:block}
  .panel{padding:16px 14px 76px}
}
/* PROGRESS RING for exam pct */
.ring-svg{transform:rotate(-90deg)}
.ring-bg{fill:none;stroke:var(--bg4);stroke-width:4}
.ring-fill{fill:none;stroke:var(--amber);stroke-width:4;stroke-linecap:round;transition:stroke-dashoffset .8s ease}
</style>
</head>
