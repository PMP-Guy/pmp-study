// ── HTML → Markdown (for saving) ──────────────────────────────────────────
function htmlToMd(html){
  const d=document.createElement('div');d.innerHTML=html;
  return nodeToMd(d).trim();
}
function nodeToMd(node){
  let out='';
  for(const c of node.childNodes){
    if(c.nodeType===3){out+=c.textContent;}
    else if(c.nodeType===1){
      const t=c.tagName.toLowerCase();
      const inner=nodeToMd(c);
      if(t==='h1')out+=`# ${inner}\n`;
      else if(t==='h2')out+=`## ${inner}\n`;
      else if(t==='h3')out+=`### ${inner}\n`;
      else if(t==='strong'||t==='b')out+=`**${inner}**`;
      else if(t==='em'||t==='i')out+=`_${inner}_`;
      else if(t==='s')out+=`~~${inner}~~`;
      else if(t==='u')out+=`<u>${inner}</u>`;
      else if(t==='code')out+='`'+inner+'`';
      else if(t==='pre')out+='```\n'+c.textContent+'\n```\n';
      else if(t==='blockquote')out+=`> ${inner}\n`;
      else if(t==='li')out+=`- ${inner}\n`;
      else if(t==='ul'||t==='ol')out+=inner;
      else if(t==='br')out+='\n';
      else if(t==='p'||t==='div')out+=inner+(inner.endsWith('\n')?'':'\n');
      else if(t==='hr')out+='---\n';
      else if(t==='a')out+=`[${inner}](${c.href})`;
      else if(t==='span'){
        const cls=c.className;
        const color=cls.replace('hl-','');
        if(cls.startsWith('hl-'))out+=`==${inner}==${color}`;
        else out+=inner;
      }
      else out+=inner;
    }
  }
  return out;
}

