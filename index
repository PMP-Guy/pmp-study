<div class="rsect"><div class="rtitle">EVM formulas — master all 16</div>
  <div class="fg">
    <div class="fcard"><div class="fn">Earned Value (EV)</div><div class="fv">% complete × BAC</div></div>
    <div class="fcard"><div class="fn">CPI (cost efficiency)</div><div class="fv">EV / AC</div></div>
    <div class="fcard"><div class="fn">SPI (schedule efficiency)</div><div class="fv">EV / PV</div></div>
    <div class="fcard"><div class="fn">CV (cost variance)</div><div class="fv">EV − AC</div></div>
    <div class="fcard"><div class="fn">SV (schedule variance)</div><div class="fv">EV − PV</div></div>
    <div class="fcard"><div class="fn">EAC (at current CPI)</div><div class="fv">BAC / CPI</div></div>
    <div class="fcard"><div class="fn">EAC (optimistic)</div><div class="fv">AC + (BAC−EV)</div></div>
    <div class="fcard"><div class="fn">EAC (new estimate)</div><div class="fv">AC + ETC</div></div>
    <div class="fcard"><div class="fn">ETC (remaining work)</div><div class="fv">EAC − AC</div></div>
    <div class="fcard"><div class="fn">VAC (variance at completion)</div><div class="fv">BAC − EAC</div></div>
    <div class="fcard"><div class="fn">TCPI (required efficiency)</div><div class="fv">(BAC−EV) / (BAC−AC)</div></div>
    <div class="fcard"><div class="fn">PERT estimate</div><div class="fv">(O + 4M + P) / 6</div></div>
    <div class="fcard"><div class="fn">Std deviation (PERT)</div><div class="fv">(P − O) / 6</div></div>
    <div class="fcard"><div class="fn">Communication channels</div><div class="fv">n(n−1) / 2</div></div>
    <div class="fcard"><div class="fn">Total Float</div><div class="fv">LF−EF or LS−ES</div></div>
    <div class="fcard"><div class="fn">BCR</div><div class="fv">Benefits / Costs</div></div>
  </div>
  <div style="margin-top:14px;font-size:12px;color:var(--text3);line-height:1.7">
    <strong style="color:var(--text2)">Key rules to memorise:</strong><br>
    CPI &gt; 1.0 = under budget · CPI &lt; 1.0 = over budget · SPI &gt; 1.0 = ahead of schedule · SPI &lt; 1.0 = behind schedule<br>
    TCPI &gt; 1.10 is generally considered unachievable without scope reduction<br>
    Negative CV = cost overrun · Negative SV = behind schedule
  </div>
