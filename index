// ── Markdown parser (no dependencies) ─────────────────────────────────────
function mdToHtml(md){
  if(!md)return '';
  let h=md
    // Code blocks first (before inline)
    .replace(/```([\s\S]*?)```/g,(_,c)=>`<pre>${esc(c.trim())}</pre>`)
    // Headings
    .replace(/^### (.+)$/gm,'<h3>$1</h3>')
    .replace(/^## (.+)$/gm,'<h2>$1</h2>')
    .replace(/^# (.+)$/gm,'<h1>$1</h1>')
    // HR
    .replace(/^---$/gm,'<hr>')
    // Blockquote
    .replace(/^> (.+)$/gm,'<blockquote>$1</blockquote>')
    // Bold + italic
    .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/__(.+?)__/g,'<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,'<em>$1</em>')
    .replace(/_(.+?)_/g,'<em>$1</em>')
    // Strikethrough
    .replace(/~~(.+?)~~/g,'<s>$1</s>')
    // Inline code
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    // Highlights (custom syntax ==text==colorname)
    .replace(/==(.+?)==(red|amber|green|blue|purple)/g,'<span class="hl-$2">$1</span>')
    .replace(/==(.+?)==/g,'<span class="hl-amber">$1</span>')
    // Links
    .replace(/\[(.+?)\]\((.+?)\)/g,'<a href="$2" target="_blank">$1</a>')
    // Bullet lists
    .replace(/^[\-\*] (.+)$/gm,'<li>$1</li>')
    .replace(/(<li>.*<\/li>)/gs,m=>`<ul>${m}</ul>`)
    // Numbered lists
    .replace(/^\d+\. (.+)$/gm,'<li>$1</li>')
    // Paragraphs (blank lines)
    .replace(/\n\n/g,'</p><p>')
    .replace(/\n/g,'<br>');
  return h;
}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

