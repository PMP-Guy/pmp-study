<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>PMP Study Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Lora:ital,wght@0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0e0f13;--bg2:#14151a;--bg3:#1c1d24;--bg4:#24252f;--bg5:#2e303a;
  --glass:rgba(255,255,255,.04);--glass2:rgba(255,255,255,.07);--glass3:rgba(255,255,255,.11);
  --border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.12);--border3:rgba(255,255,255,.18);
  --text:#eeeef0;--text2:#9a9ba8;--text3:#5e5f6e;--text4:#3a3b48;
  --amber:#f5a623;--amber2:#fbbf5a;--amber3:rgba(245,166,35,.15);
  --green:#22c98a;--green2:rgba(34,201,138,.15);
  --red:#f25858;--red2:rgba(242,88,88,.15);
  --blue:#5b9cf6;--blue2:rgba(91,156,246,.15);
  --purple:#a78bfa;--purple2:rgba(167,139,250,.15);
  --people:#f25858;--people2:rgba(242,88,88,.12);
  --process:#22c98a;--process2:rgba(34,201,138,.12);
  --biz:#5b9cf6;--biz2:rgba(91,156,246,.12);
  --r:8px;--r2:14px;--r3:20px;--r4:28px;
  --ff:'Plus Jakarta Sans',sans-serif;--fd:'Lora',serif;--fm:'JetBrains Mono',monospace;
  --sh:0 0 0 1px var(--border),0 4px 24px rgba(0,0,0,.4);
  --sh2:0 0 0 1px var(--border2),0 8px 40px rgba(0,0,0,.6);
}
*{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
body{background:var(--bg);color:var(--text);font-family:var(--ff);line-height:1.6;min-height:100vh;overflow-x:hidden}
/* Background mesh */
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 50% at 20% 0%,rgba(245,166,35,.06) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 100%,rgba(91,156,246,.05) 0%,transparent 60%);pointer-events:none;z-index:0}
::selection{background:rgba(245,166,35,.3);color:var(--text)}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg2)}::-webkit-scrollbar-thumb{background:var(--bg5);border-radius:2px}

/* ── SHELL ─────────────────────────────────────────────── */
.app{display:grid;grid-template-columns:72px 220px 1fr;grid-template-rows:1fr;height:100vh;position:relative;z-index:1}

/* ── ICON RAIL ─────────────────────────────────────────── */
.rail{background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:16px 0;gap:4px;z-index:10}
.rail-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--amber),#e8870a);display:flex;align-items:center;justify-content:center;margin-bottom:12px;flex-shrink:0}
.rail-logo svg{width:18px;height:18px;fill:#000}
.ri{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .18s;color:var(--text3);flex-shrink:0;position:relative}
.ri svg{width:18px;height:18px;stroke:currentColor;stroke-width:1.8;fill:none}
.ri:hover{background:var(--glass2);color:var(--text2)}
.ri.on{background:var(--amber3);color:var(--amber)}
.ri-tip{position:absolute;left:52px;background:var(--bg4);color:var(--text);font-size:11px;padding:4px 9px;border-radius:6px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .15s;border:1px solid var(--border2);font-family:var(--ff)}
.ri:hover .ri-tip{opacity:1}
.rail-div{width:28px;height:1px;background:var(--border);margin:6px 0}

/* ── SIDEBAR ───────────────────────────────────────────── */
.sidebar{background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sb-top{padding:18px 16px 12px;border-bottom:1px solid var(--border)}
.sb-title{font-family:var(--fd);font-size:15px;font-style:italic;color:var(--text);font-weight:500;line-height:1.2}
.sb-sub{font-size:11px;color:var(--text3);margin-top:2px;font-family:var(--fm)}

/* TIMER ───────────────────────────── */
.timer-section{padding:16px;border-bottom:1px solid var(--border)}
.timer-ring-wrap{position:relative;width:100px;height:100px;margin:0 auto 12px}
.timer-ring-wrap svg{transform:rotate(-90deg);filter:drop-shadow(0 0 12px rgba(245,166,35,.3))}
.tr-bg{fill:none;stroke:var(--bg4);stroke-width:6}
.tr-main{fill:none;stroke:var(--amber);stroke-width:6;stroke-linecap:round;stroke-dasharray:283;stroke-dashoffset:0;transition:stroke-dashoffset .95s linear}
.tr-main.break{stroke:var(--green)}
.timer-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px}
.timer-time{font-family:var(--fm);font-size:20px;font-weight:500;color:var(--text);letter-spacing:.02em;line-height:1}
.timer-phase{font-family:var(--fm);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em}
.timer-mode-strip{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.timer-mode-name{font-size:12px;color:var(--text2);font-weight:500}
.timer-session-info{font-family:var(--fm);font-size:10px;color:var(--text3)}
.timer-dots{display:flex;gap:4px;justify-content:center;margin-bottom:10px}
.td{width:8px;height:8px;border-radius:50%;background:var(--bg4);transition:all .3s}
.td.done{background:var(--amber)}
.td.cur{background:var(--amber);box-shadow:0 0 8px var(--amber)}
.td.brk.done{background:var(--green)}
.tbns{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px}
.tbn{padding:6px 0;border-radius:var(--r);border:1px solid var(--border2);background:transparent;color:var(--text2);font-size:11px;font-family:var(--ff);cursor:pointer;transition:all .16s;text-align:center}
.tbn:hover{background:var(--glass2);color:var(--text)}
.tbn.go{background:var(--amber);border-color:var(--amber);color:#000;font-weight:600}
.tbn.go:hover{background:#d9920a}
.tbn.go.paused{background:var(--bg4);border-color:var(--border2);color:var(--text)}
/* Active session banner */
.session-active-banner{margin-top:10px;background:linear-gradient(135deg,rgba(34,201,138,.12),rgba(34,201,138,.06));border:1px solid rgba(34,201,138,.25);border-radius:var(--r);padding:8px 10px;display:none}
.sab-title{font-size:11px;font-weight:600;color:var(--green);margin-bottom:3px}
.sab-elapsed{font-family:var(--fm);font-size:13px;color:var(--text);font-weight:500}
.sab-since{font-size:10px;color:var(--text3)}
.sab-btns{display:flex;gap:5px;margin-top:8px}

/* EXAM COUNTDOWN ──────────────────── */
.exam-box{padding:14px 16px;border-bottom:1px solid var(--border)}
.ex-days{font-family:var(--fm);font-size:32px;font-weight:500;color:var(--amber);line-height:1}
.ex-lbl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.09em;font-family:var(--fm)}
.ex-date{font-size:11px;color:var(--text3);margin-top:4px}
.ex-progress{margin-top:10px}
.ex-prog-lbl{display:flex;justify-content:space-between;font-size:10px;color:var(--text3);font-family:var(--fm);margin-bottom:4px}
.ex-prog-bar{height:3px;background:var(--bg4);border-radius:2px;overflow:hidden}
.ex-prog-fill{height:3px;background:linear-gradient(90deg,var(--amber),var(--amber2));border-radius:2px;transition:width .6s}

/* QUICK STATS ─────────────────────── */
.sb-stats{padding:12px 16px;display:flex;flex-direction:column;gap:7px}
.sb-stat{display:flex;justify-content:space-between;align-items:center}
.sb-stat-l{font-size:11px;color:var(--text3)}
.sb-stat-v{font-family:var(--fm);font-size:12px;color:var(--text2);font-weight:500}

/* ── MAIN ──────────────────────────────────────────────── */
.main{overflow-y:auto;background:var(--bg);position:relative}
.panel{display:none;padding:28px 32px;min-height:100%;animation:pi .2s ease}
.panel.on{display:block}
@keyframes pi{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.ph{margin-bottom:24px}
.pt{font-family:var(--fd);font-size:22px;font-weight:500;color:var(--text);line-height:1.25;letter-spacing:-.01em}
.pt em{font-style:italic;color:var(--amber)}
.ps{font-size:12px;color:var(--text3);margin-top:4px}

/* METRICS ────────────────────── */
.mets{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px}
.met{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:16px;position:relative;overflow:hidden;transition:border-color .2s}
.met:hover{border-color:var(--border2)}
.met::after{content:'';position:absolute;top:-20px;right:-20px;width:70px;height:70px;border-radius:50%;opacity:.08}
.met.a::after{background:var(--amber)}
.met.g::after{background:var(--green)}
.met.r::after{background:var(--red)}
.met.b::after{background:var(--blue)}
.met-v{font-family:var(--fm);font-size:26px;font-weight:500;line-height:1;position:relative}
.met.a .met-v{color:var(--amber)}
.met.g .met-v{color:var(--green)}
.met.r .met-v{color:var(--red)}
.met.b .met-v{color:var(--blue)}
.met-l{font-size:11px;color:var(--text3);margin-top:6px}
.met-s{font-family:var(--fm);font-size:10px;color:var(--text4);margin-top:3px}

/* CARDS ─────────────────────── */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);transition:border-color .2s}
.card:hover{border-color:var(--border2)}
.ch{font-family:var(--fm);font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}

/* SCHEDULE ───────────────────── */
.sg{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-bottom:10px}
.sd{border-radius:var(--r);padding:9px 3px;text-align:center;background:var(--bg3);border:1px solid transparent;transition:.18s}
.sd.study{background:rgba(245,166,35,.08);border-color:rgba(245,166,35,.2)}
.sd.today{border-color:var(--amber)!important;box-shadow:0 0 0 1px var(--amber)}
.sd.rest{opacity:.4}
.sd-d{font-family:var(--fm);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em}
.sd-h{font-family:var(--fm);font-size:16px;font-weight:500;color:var(--amber);margin:2px 0;line-height:1}
.sd.rest .sd-h{color:var(--text4);font-size:11px}
.sd-t{font-size:9px;color:var(--text3)}

/* LOG ────────────────────────── */
.lr{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}
.lr:last-child{border-bottom:none}
.lr-dt{font-family:var(--fm);font-size:10px;color:var(--text3);width:68px;flex-shrink:0}
.lr-sc{font-family:var(--fm);font-size:11px;font-weight:500;width:36px;flex-shrink:0}
.lr-tp{font-size:12px;color:var(--text2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.lr-h{font-family:var(--fm);font-size:10px;color:var(--text3)}
.lr-dur{font-family:var(--fm);font-size:10px;color:var(--text4)}
.sg{color:var(--green)}.sm{color:var(--amber)}.sb2{color:var(--red)}

/* DOMAIN BARS ───────────────── */
.dr{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.dn{font-size:12px;color:var(--text2);width:185px;flex-shrink:0}
.dp{font-family:var(--fm);font-size:11px;color:var(--text3);width:32px;text-align:right;flex-shrink:0}
.pb{background:var(--bg4);border-radius:100px;height:6px;flex:1;overflow:hidden}
.pf{height:6px;border-radius:100px;transition:width .8s cubic-bezier(.34,1.2,.64,1)}

/* ACTIVITY ───────────────────── */
.agrid{display:flex;flex-wrap:wrap;gap:3px}
.dot{width:13px;height:13px;border-radius:3px;background:var(--bg4);transition:.2s}
.dot.on{background:var(--amber);opacity:.8}
.dot.tod{background:var(--green);box-shadow:0 0 6px rgba(34,201,138,.4)}
.dot.wk{background:var(--bg3);border:1px solid var(--bg4)}

/* MOTIVATION CARD ────────────── */
.motive-card{background:linear-gradient(135deg,rgba(245,166,35,.08),rgba(245,166,35,.03));border:1px solid rgba(245,166,35,.2);border-radius:var(--r2);padding:18px 20px;margin-bottom:12px;position:relative;overflow:hidden}
.motive-card::before{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:radial-gradient(circle,rgba(245,166,35,.12),transparent);pointer-events:none}
.motive-q{font-family:var(--fd);font-size:14px;font-style:italic;color:var(--text);line-height:1.6;position:relative}
.motive-src{font-size:11px;color:var(--text3);margin-top:8px;font-family:var(--fm)}
.motive-tip{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:14px 16px;margin-bottom:12px}
.motive-tip-head{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.motive-tip-icon{font-size:16px}
.motive-tip-label{font-size:11px;font-family:var(--fm);color:var(--text3);text-transform:uppercase;letter-spacing:.08em}
.motive-tip-text{font-size:13px;color:var(--text2);line-height:1.6}

/* BUTTONS ────────────────────── */
.btn{font-family:var(--ff);font-size:12px;font-weight:500;padding:8px 16px;border-radius:var(--r);border:1px solid var(--border2);background:var(--glass);color:var(--text);cursor:pointer;transition:all .16s;display:inline-flex;align-items:center;gap:6px;line-height:1.2}
.btn:hover{background:var(--glass2);border-color:var(--border3)}
.btn-p{background:var(--amber);border-color:var(--amber);color:#000;font-weight:600}
.btn-p:hover{background:#d9920a;border-color:#d9920a}
.btn-g{background:rgba(34,201,138,.15);border-color:rgba(34,201,138,.35);color:var(--green)}
.btn-g:hover{background:rgba(34,201,138,.22)}
.btn-r{border-color:rgba(242,88,88,.4);color:var(--red)}
.btn-r:hover{background:var(--red2)}
.btn-sm{padding:5px 11px;font-size:11px}
.btn-xs{padding:3px 9px;font-size:10px}

/* FORMS ─────────────────────── */
input,textarea,select{font-family:var(--ff);font-size:12px;color:var(--text);background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r);padding:8px 11px;outline:none;width:100%;transition:border .15s,background .15s}
input:focus,textarea:focus,select:focus{border-color:var(--amber);background:var(--bg4)}
textarea{resize:vertical;min-height:85px;line-height:1.65}
select option{background:var(--bg3)}
.fl{display:block;font-family:var(--fm);font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.fld{margin-bottom:11px}

/* FILTER CHIPS ──────────────── */
.filters{display:flex;gap:6px;flex-wrap:wrap;align-items:center;margin-bottom:14px}
.fc{font-size:11px;font-family:var(--fm);padding:4px 12px;border-radius:100px;border:1px solid var(--border2);background:transparent;color:var(--text3);cursor:pointer;transition:.16s}
.fc:hover{color:var(--text);border-color:var(--border3)}
.fc.on{font-weight:500}
.fc.fall.on{background:rgba(255,255,255,.1);border-color:var(--border3);color:var(--text)}
.fc.fp.on{background:var(--people2);border-color:rgba(242,88,88,.4);color:var(--red)}
.fc.fr.on{background:var(--process2);border-color:rgba(34,201,138,.35);color:var(--green)}
.fc.fb.on{background:var(--biz2);border-color:rgba(91,156,246,.35);color:var(--blue)}
.fc.fa.on{background:var(--purple2);border-color:rgba(167,139,250,.35);color:var(--purple)}

/* SESSION BAR ───────────────── */
.sbar{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:12px 16px;display:flex;align-items:center;gap:16px;margin-bottom:14px}
.ss-v{font-family:var(--fm);font-size:20px;font-weight:500;line-height:1}
.ss-l{font-family:var(--fm);font-size:9px;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-top:2px}
.ss-pbg{background:var(--bg4);border-radius:100px;height:6px;flex:1;overflow:hidden}
.ss-pf{height:6px;border-radius:100px;transition:width .4s,background .4s;background:var(--green)}

/* QUESTION ──────────────────── */
.qcard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:22px;margin-bottom:12px;transition:border-color .2s}
.qmeta{display:flex;align-items:center;gap:6px;margin-bottom:14px;flex-wrap:wrap}
.qdb{font-family:var(--fm);font-size:10px;padding:3px 9px;border-radius:100px;font-weight:500}
.qdb-p{background:var(--people2);color:var(--red);border:1px solid rgba(242,88,88,.25)}
.qdb-r{background:var(--process2);color:var(--green);border:1px solid rgba(34,201,138,.25)}
.qdb-b{background:var(--biz2);color:var(--blue);border:1px solid rgba(91,156,246,.25)}
.qsub{font-family:var(--fm);font-size:10px;padding:3px 9px;border-radius:100px;background:var(--bg3);color:var(--text3);border:1px solid var(--border)}
.qn{font-family:var(--fm);font-size:10px;color:var(--text4);margin-left:auto}
.qtext{font-size:15px;line-height:1.8;color:var(--text);margin-bottom:18px;font-weight:400}
.opts{display:flex;flex-direction:column;gap:7px}
.opt{display:flex;align-items:flex-start;gap:11px;padding:11px 14px;border:1px solid var(--border2);border-radius:var(--r);cursor:pointer;font-size:13px;color:var(--text2);line-height:1.55;transition:.16s;background:var(--bg3)}
.opt:hover{border-color:var(--border3);background:var(--bg4);color:var(--text)}
.opt.sel{border-color:var(--amber);background:rgba(245,166,35,.06);color:var(--text)}
.opt.ok{border-color:rgba(34,201,138,.5);background:rgba(34,201,138,.07);color:var(--green)}
.opt.bad{border-color:rgba(242,88,88,.5);background:rgba(242,88,88,.07);color:var(--red)}
.opt.locked{cursor:default}
.ol{width:21px;height:21px;border-radius:50%;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:10px;font-family:var(--fm);font-weight:500;flex-shrink:0;margin-top:1px}
.opt.ok .ol,.opt.bad .ol{color:#fff;border:none}
.opt.ok .ol{background:var(--green)}
.opt.bad .ol{background:var(--red)}
.expl{border-left:3px solid var(--green);background:rgba(34,201,138,.05);border-radius:0 var(--r) var(--r) 0;padding:14px 16px;margin-top:14px;font-size:12px;line-height:1.72;color:var(--text2)}
.expl strong{color:var(--green);font-weight:600}
.expl.ex-bad{border-left-color:var(--red);background:rgba(242,88,88,.05)}
.expl.ex-bad strong{color:var(--red)}
.qact{display:flex;gap:8px;align-items:center;margin-top:12px;flex-wrap:wrap}

/* NOTES ─────────────────────── */
.notes-layout{display:grid;grid-template-columns:380px 1fr;gap:16px;align-items:start}
.nform{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:18px;position:sticky;top:16px;max-height:calc(100vh - 100px);overflow-y:auto}
.nform-title{font-family:var(--fd);font-size:15px;font-style:italic;color:var(--text);margin-bottom:12px;font-weight:500}
.tag-row{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:11px}
.tag-b{font-size:10px;font-family:var(--fm);padding:3px 10px;border-radius:100px;border:1px solid var(--border2);background:transparent;color:var(--text3);cursor:pointer;transition:.14s}
.tag-b:hover{color:var(--text);border-color:var(--border3)}
.tag-b.on{font-weight:500}
.tag-b[data-t="People"].on{background:var(--people2);border-color:rgba(242,88,88,.35);color:var(--red)}
.tag-b[data-t="Process"].on{background:var(--process2);border-color:rgba(34,201,138,.35);color:var(--green)}
.tag-b[data-t="Business"].on{background:var(--biz2);border-color:rgba(91,156,246,.35);color:var(--blue)}
.tag-b[data-t="Formula"].on{background:var(--amber3);border-color:rgba(245,166,35,.35);color:var(--amber)}
.tag-b[data-t="Agile"].on{background:var(--purple2);border-color:rgba(167,139,250,.35);color:var(--purple)}
.tag-b[data-t="Ethics"].on{background:rgba(34,201,138,.1);border-color:rgba(34,201,138,.3);color:var(--green)}
/* Rich editor toolbar */
.editor-wrap{border:1px solid var(--border2);border-radius:var(--r);overflow:hidden;margin-bottom:10px;background:var(--bg3)}
.editor-wrap:focus-within{border-color:var(--amber)}
.toolbar{display:flex;flex-wrap:wrap;gap:1px;padding:6px 8px;background:var(--bg4);border-bottom:1px solid var(--border)}
.tb-group{display:flex;gap:1px;margin-right:4px}
.tb-sep{width:1px;background:var(--border2);margin:0 3px;align-self:stretch}
.tbtn2{width:26px;height:26px;border-radius:5px;border:none;background:transparent;color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;font-family:var(--ff);transition:all .14s;flex-shrink:0;line-height:1}
.tbtn2:hover{background:var(--glass2);color:var(--text)}
.tbtn2.on{background:var(--amber3);color:var(--amber)}
.tbtn2 svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none;pointer-events:none}
.color-dot{width:14px;height:14px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:.14s;flex-shrink:0}
.color-dot:hover,.color-dot.on{border-color:var(--text);transform:scale(1.15)}
.hl-strip{display:flex;align-items:center;gap:3px}
/* contenteditable editor area */
#editor{min-height:160px;max-height:300px;overflow-y:auto;padding:10px 12px;font-size:13px;color:var(--text2);line-height:1.75;outline:none;font-family:var(--ff);word-break:break-word}
#editor:empty::before{content:attr(data-placeholder);color:var(--text4);pointer-events:none}
#editor h1{font-family:var(--fd);font-size:17px;font-weight:600;color:var(--text);margin:8px 0 4px;line-height:1.3}
#editor h2{font-family:var(--fd);font-size:14px;font-weight:600;color:var(--text);margin:7px 0 3px;line-height:1.3}
#editor h3{font-size:13px;font-weight:600;color:var(--text);margin:5px 0 2px;text-transform:uppercase;letter-spacing:.05em}
#editor b,#editor strong{font-weight:700;color:var(--text)}
