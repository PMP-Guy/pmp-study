// Notes-specific export/import/clear
function expNotes(){
  const b=new Blob([JSON.stringify(S.notes,null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(b);
  a.download='pmp_notes_'+new Date().toISOString().split('T')[0]+'.json';a.click();
  toast('Notes exported ✓','ok');
}
function impNotes(e){
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{
    try{
      const notes=JSON.parse(ev.target.result);
      if(!Array.isArray(notes))throw new Error('Not an array');
      // Merge: avoid duplicates by id
      const existingIds=new Set(S.notes.map(n=>n.id));
      const newNotes=notes.filter(n=>!existingIds.has(n.id));
      S.notes=[...S.notes,...newNotes];
      lsSaveNotesOnly();renderNotes();
      toast(`Imported ${newNotes.length} note${newNotes.length===1?'':'s'} ✓`,'ok');
    }catch(x){toast('Invalid notes file','err');}
  };r.readAsText(f);
}
function clrNotes(){
  if(confirm('Delete ALL notes? This cannot be undone.\n\nExport them first if you want a backup.')){
    S.notes=[];openNotes.clear();
    lsSaveNotesOnly();renderNotes();
    toast('All notes cleared');
  }
}

